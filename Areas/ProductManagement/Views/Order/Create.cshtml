@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Mvc.TagHelpers
@using SmartInventoryManagementSystem.Areas.ProjectManagement.Models
@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager

@model SmartInventoryManagementSystem.Areas.ProductManagement.Models.Order

@{
    ViewBag.Title = "Place Order";
    Layout = "_Layout";

    var products = (List<Product>)ViewBag.Products;
    var isSignedIn = SignInManager.IsSignedIn(User);
    var isAdmin = User.IsInRole("Admin");

    string customerName = "";
    string customerEmail = "";

    if (isSignedIn && !isAdmin)
    {
        var user = await UserManager.GetUserAsync(User);
        if (user != null)
        {
            customerName = $"{user.FirstName} {user.LastName}";
            customerEmail = user.Email;
        }
    }
    
    var productOptionsHtml = "";
    foreach (var prod in products)
    {
        productOptionsHtml += $"<option value='{prod.ProductId}'>{prod.Name} ({prod.Price})</option>";
    }
}

<h2>Place an Order</h2>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <p>@error.ErrorMessage</p>
        }
    </div>
}

<form id="orderForm" asp-action="Create" method="post">
    @if (isSignedIn && !isAdmin)
    {
        <input type="hidden" asp-for="CustomerName" value="@customerName" />
        <input type="hidden" asp-for="CustomerEmail" value="@customerEmail" />
        <div class="form-group">
            <label>Placing as: <strong>@customerName</strong> (<i>@customerEmail</i>)</label>
        </div>
    }
    else
    {
        <div class="form-group">
            <label asp-for="CustomerName" class="control-label">Customer Name</label>
            <input asp-for="CustomerName" class="form-control" />
            <span asp-validation-for="CustomerName" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="CustomerEmail" class="control-label">Customer Email</label>
            <input asp-for="CustomerEmail" class="form-control" />
            <span asp-validation-for="CustomerEmail" class="text-danger"></span>
        </div>
    }

    <h3>Select Products</h3>
    <div id="orderItems" class="form-group">
        <div class="orderItem">
            <label class="control-label">Product:</label>
            <select name="productIds" class="form-control">
                @foreach (var prod in products)
                {
                    <option value="@prod.ProductId">@prod.Name (@prod.Price)</option>
                }
            </select>
            <label class="control-label">Quantity:</label>
            <input type="number" name="quantities" class="form-control" min="1" value="1" />
        </div>
    </div>

    <br />
    <button type="button" class="btn btn-primary" onclick="addOrderItem()">Add Another Product</button>
    <br /><br />
    <button type="submit" class="btn btn-primary">Place Order</button>
</form>

<!-- spinner -->
<div id="spinner" style="display:none; text-align:center; font-size:40px;">
    <i class="fa-solid fa-rotate fa-spin"></i>
</div>

<div id="orderConfirmationContainer" style="margin-top:20px;"></div>

@section Scripts {
    <script>
        window.orderProductsOptionsHTML = '@Html.Raw(productOptionsHtml)';
    </script>
    <script src="~/js/orderForm.js"></script>
}