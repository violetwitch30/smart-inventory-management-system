@using Microsoft.AspNetCore.Identity
@using SmartInventoryManagementSystem.Areas.ProjectManagement.Models
@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager

@model SmartInventoryManagementSystem.Areas.ProductManagement.Models.Order

@{
    ViewBag.Title = "Track Order";
    Layout = "_Layout";

    var isSignedIn = SignInManager.IsSignedIn(User);
    var isAdmin = User.IsInRole("Admin");

    string customerName = "";
    string customerEmail = "";

    if (isSignedIn && !isAdmin)
    {
        var user = await UserManager.GetUserAsync(User);
        if (user != null)
        {
            customerName = $"{user.FirstName} {user.LastName}";
            customerEmail = user.Email;
        }
    }
}

<h2>Track Order</h2>

<form asp-action="Track" method="post">
    @if (isSignedIn && !isAdmin)
    {
        <input type="hidden" name="customerName" value="@customerName" />
        <input type="hidden" name="customerEmail" value="@customerEmail" />
        <div class="form-group">
            <label>Tracking as:</label>
            <p><strong>@customerName</strong> (<i>@customerEmail</i>)</p>
        </div>
    }
    else
    {
        <div class="form-group">
            <label for="customerName">Customer Name</label>
            <input type="text" id="customerName" name="customerName" class="form-control" />
        </div>
        <div class="form-group">
            <label for="customerEmail">Customer Email</label>
            <input type="email" id="customerEmail" name="customerEmail" class="form-control" />
        </div>
    }

    <br />
    <div class="form-group">
        <input type="submit" value="Track" class="btn btn-primary" />
    </div>
</form>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}