<!-- SEARCH AND FILTER FORM -->
@using Assignment1.Areas.ProductManagement.Models
@model IEnumerable<Assignment1.Areas.ProductManagement.Models.Product>
@{
    ViewBag.Title = "Search Products";
}

<h2>Search Products</h2>

<form method="get" asp-action="Search">
    
    <div class="form-group">
        <label class="control-label">Search</label>
        <input type="text" name="searchString" class="form-control" placeholder="Search products..." value="@Context.Request.Query["searchString"]"/>
    </div>

    <!-- category -->
    <div class="form-group">
        <label class="control-label">Category</label>
        <select name="categoryId" class="form-control">
            <option value="">All Categories</option>
            @foreach (var category in (List<Category>)ViewBag.Categories ?? new List<Category>())
            {
                <option value="@category.CategoryId" selected="@(category.CategoryId.ToString() == Context.Request.Query["categoryId"] ? "selected" : null)">
                    @category.Name
                </option>
            }
        </select>
    </div>

    <!-- price range -->
    <div class="form-group">
        <label class="control-label">Min Price</label>
        <input type="number" name="minPrice" class="form-control" value="@Context.Request.Query["minPrice"]"/>
    </div>

    <div class="form-group">
        <label class="control-label">Max Price</label>
        <input type="number" name="maxPrice" class="form-control" value="@Context.Request.Query["maxPrice"]"/>
    </div>

    <!-- low stock -->
    <div class="form-group">
        <label class="control-label">
            <input type="checkbox" name="lowStockOnly" value="true" @(Context.Request.Query["lowStockOnly"] == "true" ? "checked" : "")/>
            Show only low-stock products (less than 10)
        </label>
    </div>

    <!-- sorting -->
    <div class="form-group">
        <label class="control-label">Filter</label>
        <select name="sortOrder" class="form-control">
            <option value="">Sort By</option>
            <option value="name_asc" selected="@(Context.Request.Query["sortOrder"] == "name_asc" ? "selected" : null)">Name (A-Z)</option>
            <option value="name_desc" selected="@(Context.Request.Query["sortOrder"] == "name_desc" ? "selected" : null)">Name (Z-A)</option>
            <option value="price_asc" selected="@(Context.Request.Query["sortOrder"] == "price_asc" ? "selected" : null)">Price (Low to High)</option>
            <option value="price_desc" selected="@(Context.Request.Query["sortOrder"] == "price_desc" ? "selected" : null)">Price (High to Low)</option>
            <option value="quantity_asc" selected="@(Context.Request.Query["sortOrder"] == "quantity_asc" ? "selected" : null)">Quantity (Low to High)</option>
            <option value="quantity_desc" selected="@(Context.Request.Query["sortOrder"] == "quantity_desc" ? "selected" : null)">Quantity (High to Low)</option>
        </select>
    </div>

    <br/>
    <button type="submit" class="btn btn-secondary">Search</button>
</form>

<table class="table">
    <thead>
    <tr>
        <th>Product Name</th>
        <th>Description</th>
        <th>Category</th>
        <th>Price</th>
        <th>Quantity</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var product in Model)
    {
        <tr class="@(product.Quantity < 10 ? "table-danger" : "")">
            <td>@product.Name</td>
            <td>@product.Description</td>
            <td>@product.Category.Name</td>
            <td>@product.Price</td>
            <td>@product.Quantity</td>
        </tr>
    }
    </tbody>
</table>

<!-- low-stock red colour alert -->
<style>
    .table-danger {
        background-color: darkred;
    }
</style>