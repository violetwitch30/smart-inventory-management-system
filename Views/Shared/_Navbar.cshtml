@using Microsoft.AspNetCore.Mvc.TagHelpers
@using SmartInventoryManagementSystem.Areas.ProjectManagement.Models
@inject SignInManager<ApplicationUser> SignInManager
<nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
        <div class="container-fluid">
            <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Inventory</a>
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            
            <div class="navbar-collapse collapse d-sm-inline-flex flex-sm-row-reverse">
                <ul class="navbar-nav flex-grow-1 justify-content-end">
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index"><i class="fa-solid fa-house-chimney"></i> Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="About"><i class="fa-solid fa-circle-info"></i> About</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="ProductManagement" asp-controller="Product" asp-action="Index"><i class="fa-solid fa-tag"></i> Products</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="ProductManagement" asp-controller="Product" asp-action="Search"><i class="fa-solid fa-magnifying-glass"></i> Search</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="ProductManagement" asp-controller="Order" asp-action="Create"><i class="fa-solid fa-cart-shopping"></i> Place an Order</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="ProductManagement" asp-controller="Order" asp-action="Track"><i class="fa-solid fa-truck-fast"></i> Track an Order</a>
                    </li>

                    @if (SignInManager.IsSignedIn(User))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-dark"
                               asp-area="Identity"
                               asp-page="/Account/Manage/Index"
                               title="Manage your Profile"><i class="fa-solid fa-user-settings"></i> Profile
                            </a>
                        </li>

                        <li class="nav-item">
                            <form asp-area="Identity" asp-page="/Account/Logout" method="post">
                                <button type="submit" class="nav-link btn btn-link text-dark" style="cursor: pointer"> Logout</button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link text-dark"
                               asp-area="Identity"
                               asp-page="/Account/Login">
                                <i class="fa fa-sign-in-alt"></i> Login
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark"
                               asp-area="Identity"
                               asp-page="/Account/Register">
                                <i class="fa-solid fa-user-plus"></i> Register
                            </a>
                        </li>
                    }
                    
                </ul>
            </div>
            
        </div>
    </nav>